        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vergleiche die Buchstaben mit den Zahlen darunter: dieselbe Zahl steht immer fuer denselben Buchstaben. Tippe auf das markierte Feld."
